@{
    ViewData["Title"] = "Admin Paneli";
    var recentOrders = ViewBag.RecentOrders as IEnumerable<dynamic>;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="p-4 rounded-4 shadow-sm text-white" style="background: linear-gradient(135deg, #1e1b4b 0%, #311042 100%); border-left: 5px solid #8b5cf6;">
                <h1 class="display-6 fw-bold m-0"><i class="fas fa-chart-pie me-3 text-cyan"></i>Yönetici Kontrol Paneli</h1>
                <p class="lead m-0 mt-1 text-light-50">Sistem genelindeki istatistikleri ve en son siparişleri bu ekrandan takip edebilirsiniz.</p>
            </div>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="row">
        <!-- Customers -->
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative" style="background: #152039; transition: transform 0.3s ease;">
                <div class="p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase font-weight-bold text-muted mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">Müşteriler</p>
                            <h3 class="display-6 fw-bold mb-0 text-white">@ViewBag.TotalCustomers</h3>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background: rgba(59, 130, 246, 0.15); color: #3b82f6;">
                            <i class="fas fa-users fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="/Customer/Index" class="text-decoration-none text-blue d-flex align-items-center" style="font-size: 0.85rem; font-weight: 600;">
                            Tümünü Yönet <i class="fas fa-arrow-right ms-2 fs-xs"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products -->
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative" style="background: #152039; transition: transform 0.3s ease;">
                <div class="p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase font-weight-bold text-muted mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">Ürünler</p>
                            <h3 class="display-6 fw-bold mb-0 text-white">@ViewBag.TotalProducts</h3>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background: rgba(139, 92, 246, 0.15); color: #8b5cf6;">
                            <i class="fas fa-box-open fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="/Product/Index" class="text-decoration-none text-purple d-flex align-items-center" style="font-size: 0.85rem; font-weight: 600;">
                            Tümünü Yönet <i class="fas fa-arrow-right ms-2 fs-xs"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Orders -->
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative" style="background: #152039; transition: transform 0.3s ease;">
                <div class="p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase font-weight-bold text-muted mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">Siparişler</p>
                            <h3 class="display-6 fw-bold mb-0 text-white">@ViewBag.TotalOrders</h3>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background: rgba(245, 158, 11, 0.15); color: #f59e0b;">
                            <i class="fas fa-shopping-bag fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="/Order/Index" class="text-decoration-none text-warning d-flex align-items-center" style="font-size: 0.85rem; font-weight: 600;">
                            Tümünü Yönet <i class="fas fa-arrow-right ms-2 fs-xs"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Revenue -->
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative" style="background: #152039; transition: transform 0.3s ease;">
                <div class="p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase font-weight-bold text-muted mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">Toplam Ciro</p>
                            <h3 class="display-6 fw-bold mb-0 text-white">@string.Format("{0:C2}", ViewBag.TotalSales)</h3>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background: rgba(16, 185, 129, 0.15); color: #10b981;">
                            <i class="fas fa-wallet fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="/Report/Index" class="text-decoration-none text-success d-flex align-items-center" style="font-size: 0.85rem; font-weight: 600;">
                            Raporları İncele <i class="fas fa-arrow-right ms-2 fs-xs"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Orders Table -->
    <div class="row mt-2">
        <div class="col-lg-12">
            <div class="card border-0 shadow-sm rounded-4 text-white" style="background: #152039;">
                <div class="card-header border-bottom border-secondary bg-transparent p-4 d-flex align-items-center justify-content-between">
                    <h4 class="m-0 fw-bold"><i class="fas fa-history me-2 text-muted"></i> Son Siparişler</h4>
                    <span class="badge bg-primary px-3 py-2 rounded-pill">Son 5 Sipariş</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped-columns align-middle m-0 text-white">
                            <thead>
                                <tr style="background: rgba(0,0,0,0.15); border-bottom: 2px solid rgba(255,255,255,0.05);">
                                    <th class="p-3 ps-4 border-0">Sipariş ID</th>
                                    <th class="p-3 border-0">Müşteri</th>
                                    <th class="p-3 border-0">Ürün</th>
                                    <th class="p-3 border-0 text-center">Adet</th>
                                    <th class="p-3 border-0 text-end">Tutar</th>
                                    <th class="p-3 border-0">Tarih</th>
                                    <th class="p-3 pe-4 border-0 text-center">Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recentOrders != null && recentOrders.Any())
                                {
                                    @foreach (var order in recentOrders)
                                    {
                                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); transition: background-color 0.2s;">
                                            <td class="p-3 ps-4 border-0 font-weight-bold">#@order.OrderId</td>
                                            <td class="p-3 border-0">@order.CustomerName</td>
                                            <td class="p-3 border-0 text-cyan">@order.ProductName</td>
                                            <td class="p-3 border-0 text-center">@order.Quantity</td>
                                            <td class="p-3 border-0 text-end fw-bold">@string.Format("{0:C2}", order.Total)</td>
                                            <td class="p-3 border-0 text-muted" style="font-size: 0.85rem;">@order.OrderDate.ToString("g")</td>
                                            <td class="p-3 pe-4 border-0 text-center">
                                                <span class="badge @(order.Status == "Tamamlandı" ? "bg-success" : (order.Status == "Beklemede" ? "bg-warning text-dark" : "bg-info")) px-3 py-2 rounded-pill">
                                                    @order.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center p-5 text-muted border-0">
                                            <i class="fas fa-shopping-basket fa-3x mb-3 d-block"></i>
                                            Henüz sipariş bulunmuyor.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-cyan {
        color: #06b6d4 !important;
    }
    .text-blue {
        color: #3b82f6 !important;
    }
    .text-purple {
        color: #8b5cf6 !important;
    }
    .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2) !important;
    }
    table tbody tr:hover {
        background-color: rgba(255, 255, 255, 0.02) !important;
    }
</style>
