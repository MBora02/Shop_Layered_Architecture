@{
    ViewData["Title"] = "Kullanıcı Paneli";
}

<div class="container-fluid">
    <!-- Header Banner -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="p-4 rounded-4 shadow-sm text-white" style="background: linear-gradient(135deg, #1e1b4b 0%, #311042 100%); border-left: 5px solid #06b6d4;">
                <h1 class="display-6 fw-bold m-0"><i class="fas fa-chart-line me-3 text-cyan"></i>Kullanıcı Kontrol Paneli</h1>
                <p class="lead m-0 mt-1 text-light-50">Ürünlerinizi, siparişlerinizi ve hesap durumunuzu bu ekrandan takip edebilirsiniz.</p>
            </div>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="row">
        <!-- Products -->
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative" style="background: #152039; transition: transform 0.3s ease;">
                <div class="p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase font-weight-bold text-muted mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">Kayıtlı Ürünlerim</p>
                            <h3 class="display-6 fw-bold mb-0 text-white">0</h3>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background: rgba(139, 92, 246, 0.15); color: #8b5cf6;">
                            <i class="fas fa-box-open fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="text-muted" style="font-size: 0.85rem;">Henüz ürün bulunmuyor</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Orders -->
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative" style="background: #152039; transition: transform 0.3s ease;">
                <div class="p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase font-weight-bold text-muted mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">Siparişlerim</p>
                            <h3 class="display-6 fw-bold mb-0 text-white">0</h3>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background: rgba(245, 158, 11, 0.15); color: #f59e0b;">
                            <i class="fas fa-shopping-bag fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="text-muted" style="font-size: 0.85rem;">Aktif siparişiniz yok</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Support Tickets -->
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative" style="background: #152039; transition: transform 0.3s ease;">
                <div class="p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase font-weight-bold text-muted mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">Destek Talepleri</p>
                            <h3 class="display-6 fw-bold mb-0 text-white">0</h3>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background: rgba(59, 130, 246, 0.15); color: #3b82f6;">
                            <i class="fas fa-headset fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="text-muted" style="font-size: 0.85rem;">Destek talebi bulunmuyor</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Spend -->
        <div class="col-sm-6 col-lg-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative" style="background: #152039; transition: transform 0.3s ease;">
                <div class="p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-uppercase font-weight-bold text-muted mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">Toplam Harcama</p>
                            <h3 class="display-6 fw-bold mb-0 text-white">0,00 TL</h3>
                        </div>
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background: rgba(16, 185, 129, 0.15); color: #10b981;">
                            <i class="fas fa-wallet fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="text-muted" style="font-size: 0.85rem;">Harcanan toplam tutar</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Actions Table -->
    <div class="row mt-2">
        <div class="col-lg-12">
            <div class="card border-0 shadow-sm rounded-4 text-white" style="background: #152039;">
                <div class="card-header border-bottom border-secondary bg-transparent p-4 d-flex align-items-center justify-content-between">
                    <h4 class="m-0 fw-bold"><i class="fas fa-history me-2 text-muted"></i> Son Siparişler ve Ürünler</h4>
                    <span class="badge bg-primary px-3 py-2 rounded-pill">Son 5 İşlem</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                          <table class="table table-hover table-striped-columns align-middle m-0 text-white">
                              <thead>
                                  <tr style="background: rgba(0,0,0,0.15); border-bottom: 2px solid rgba(255,255,255,0.05);">
                                      <th class="p-3 ps-4 border-0">İşlem ID</th>
                                      <th class="p-3 border-0">Ürün Adı</th>
                                      <th class="p-3 border-0 text-center">Adet</th>
                                      <th class="p-3 border-0 text-end">Tutar</th>
                                      <th class="p-3 border-0">Tarih</th>
                                      <th class="p-3 pe-4 border-0 text-center">Durum</th>
                                  </tr>
                              </thead>
                              <tbody>
                                  <tr>
                                      <td colspan="6" class="text-center p-5 text-muted border-0">
                                          <i class="fas fa-shopping-basket fa-3x mb-3 d-block text-secondary"></i>
                                          Henüz kayıtlı bir ürününüz veya siparişiniz bulunmamaktadır.
                                      </td>
                                  </tr>
                              </tbody>
                          </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-cyan {
        color: #06b6d4 !important;
    }
    .text-blue {
        color: #3b82f6 !important;
    }
    .text-purple {
        color: #8b5cf6 !important;
    }
    .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2) !important;
    }
    table tbody tr:hover {
        background-color: rgba(255, 255, 255, 0.02) !important;
    }
</style>
