@model Shop.Model.Customer

<div class="row">
    <div class="col-md-12">

        <div class="card">

            <div class="card-header bg-danger">
                <h4 class="card-title text-white">
                    Müşteri Sil
                </h4>
            </div>

            <div class="card-body">

                <div class="alert alert-warning">
                    Bu müşteriyi silmek istediğinize emin misiniz?
                </div>

                <table class="table table-bordered">

                    <tr>
                        <th width="200">ID</th>
                        <td>@Model.CustomerId</td>
                    </tr>

                    <tr>
                        <th>Ad</th>
                        <td>@Model.FirstName</td>
                    </tr>

                    <tr>
                        <th>Soyad</th>
                        <td>@Model.LastName</td>
                    </tr>

                    <tr>
                        <th>Şehir</th>
                        <td>@Model.City</td>
                    </tr>

                    <tr>
                        <th>Yaş</th>
                        <td>@Model.Age</td>
                    </tr>

                    <tr>
                        <th>Telefon</th>
                        <td>@Model.Phone</td>
                    </tr>

                    <tr>
                        <th>Kayıt Tarihi</th>
                        <td>@Model.RegisterDate.ToString("dd.MM.yyyy")</td>
                    </tr>

                </table>

                <form asp-action="Delete" method="post">

                    <input asp-for="CustomerId" type="hidden" />

                    <button type="submit" class="btn btn-danger">
                        <i class="fa fa-trash"></i>
                        Sil
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        Vazgeç
                    </a>

                </form>

            </div>

        </div>

    </div>
</div>