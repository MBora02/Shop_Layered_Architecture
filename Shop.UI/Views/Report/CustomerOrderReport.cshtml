@model List<Shop.Model.viewModel.CustomerOrderVM>

<div class="row">
    <div class="col-md-12">

        <div class="card">

            <div class="card-header">
                <div class="d-flex align-items-center">
                    <h4 class="card-title">Müşteri - Sipariş Raporu</h4>
                </div>
            </div>

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-striped table-hover">

                        <thead>
                            <tr>
                                <th>Müşteri</th>
                                <th>Şehir</th>
                                <th>Sipariş Tarihi</th>
                                <th>Birim Fiyat</th>
                                <th>Adet</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.CustomerName</td>
                                    <td>@item.City</td>
                                    <td>@item.OrderDate.ToShortDateString()</td>
                                    <td>@item.UnitPrice</td>
                                    <td>@item.Quantity</td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>
</div>